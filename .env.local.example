# Browser-safe (exposed to the client)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only. NEVER expose these to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FOOTBALL_DATA_API_KEY=your-football-data-api-key
CRON_SECRET=any-random-string-you-invent

# Optional. "football-data" (default) or "openfootball" if the free tier
# does not include WC 2026. See README "Fixtures fallback".
# FIXTURES_SOURCE=football-data
